{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": ".test-dist",
    "types": ["node"],
    "jsx": "react-jsx",
    "incremental": false
  },
  "include": [
    "tests/**/*.ts",
    "src/features/face-analysis/domain/**/*.ts",
    "src/features/face-analysis/infrastructure/validators/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", ".test-dist"]
}
